generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  phone            String?
  passwordHash     String    @map("password_hash")
  role             String    @default("farmer")
  status           String    @default("active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  availability     String    @default("available")
  location         String?
  language         String    @default("en")
  bookings         Booking[] @relation("FarmerBookings")
  operatorBookings Booking[] @relation("OperatorBookings")
  fuelLogs         FuelLog[] @relation("OperatorFuelLogs")
  tractor          Tractor?  @relation("OperatorTractor")
  serviceRequests  ServiceRequest[]

  @@map("users")
}

model ServiceRequest {
  id          Int      @id @default(autoincrement())
  farmerId    Int      @map("farmer_id")
  serviceType String   @map("service_type")
  latitude    Float
  longitude   Float
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  farmer      User     @relation(fields: [farmerId], references: [id])

  @@index([farmerId], map: "service_requests_farmer_id_fkey")
  @@map("service_requests")
}

model Service {
  id                 Int       @id @default(autoincrement())
  name               String    @unique
  description        String?   @db.Text
  baseRatePerHectare Float     @map("base_rate_per_hectare")
  effectiveDate      DateTime  @default(now()) @map("effective_date")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  bookings           Booking[]

  @@map("services")
}

model SystemConfig {
  id                   Int      @id @default(1)
  dieselPrice          Float    @default(0) @map("diesel_price")
  avgMileage           Float    @default(1) @map("avg_mileage")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  contactEmail         String   @default("ops@dummy.com") @map("contact_email")
  hubLocation          String   @default("Ludhiana Central Command") @map("hub_location")
  hubName              String   @default("TractorLink Admin HQ") @map("hub_name")
  preAlertHours        Int      @default(50) @map("pre_alert_hours")
  serviceIntervalHours Int      @default(250) @map("service_interval_hours")
  supportEmail         String   @default("support@dummy.com") @map("support_email")
  baseLatitude         Float?   @map("base_latitude")
  baseLongitude        Float?   @map("base_longitude")
  perKmRate            Float    @default(500) @map("per_km_rate")
  pricingMode          String   @default("ZONE") @map("pricing_mode")

  @@map("system_config")
}

model Zone {
  id                  Int      @id @default(autoincrement())
  minDistance         Float    @map("min_distance")
  maxDistance         Float?   @map("max_distance")
  surchargePerHectare Float    @map("surcharge_per_hectare")
  status              String   @default("ACTIVE")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("zones")
}

enum BookingStatus {
  PENDING
  SCHEDULED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

model Booking {
  id             Int       @id @default(autoincrement())
  farmerId       Int       @map("farmer_id")
  serviceId      Int       @map("service_id")
  landSize       Float     @map("land_size")
  location       String
  basePrice      Float     @map("base_price")
  distanceKm     Float     @default(0) @map("distance_km")
  distanceCharge Float     @default(0) @map("distance_charge")
  fuelSurcharge  Float     @default(0) @map("fuel_surcharge")
  totalPrice     Float     @map("total_price")
  finalPrice     Float     @map("final_price")
  farmerLatitude  Float?    @map("farmer_latitude")
  farmerLongitude Float?    @map("farmer_longitude")
  airDistance     Float     @default(0) @map("air_distance")
  roadDistance    Float     @default(0) @map("road_distance")
  tractorId      Int?      @map("tractor_id")
  operatorId     Int?      @map("operator_id")
  status         BookingStatus @default(PENDING)
  scheduledAt    DateTime? @map("scheduled_at")
  paymentStatus  String    @default("pending") @map("payment_status")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  zoneName            String?   @map("zone_name")
  serviceNameSnapshot String?   @map("service_name_snapshot")
  hubName             String?   @map("hub_name")
  hubLocation         String?   @map("hub_location")
  hubLatitude         Float?    @map("hub_latitude")
  hubLongitude        Float?    @map("hub_longitude")
  farmer         User      @relation("FarmerBookings", fields: [farmerId], references: [id])
  operator       User?     @relation("OperatorBookings", fields: [operatorId], references: [id])
  service        Service   @relation(fields: [serviceId], references: [id])
  tractor        Tractor?  @relation("TractorBookings", fields: [tractorId], references: [id])
  payments       Payment[]

  @@index([farmerId], map: "bookings_farmer_id_fkey")
  @@index([operatorId], map: "bookings_operator_id_fkey")
  @@index([serviceId], map: "bookings_service_id_fkey")
  @@index([tractorId], map: "bookings_tractor_id_fkey")
  @@map("bookings")
}

model Payment {
  id        Int      @id @default(autoincrement())
  bookingId Int      @map("booking_id")
  amount    Float
  method    String   @default("cash")
  reference String?
  status    String   @default("full")
  createdAt DateTime @default(now()) @map("created_at")
  booking   Booking  @relation(fields: [bookingId], references: [id])

  @@index([bookingId], map: "payments_booking_id_fkey")
  @@map("payments")
}

model Tractor {
  id                  Int       @id @default(autoincrement())
  name                String
  model               String?
  status              String    @default("AVAILABLE")
  engineHours         Float     @default(0) @map("engine_hours")
  lastServiceDate     DateTime? @map("last_service_date")
  nextServiceDueHours Float     @default(250) @map("next_service_due_hours")
  operatorId          Int?      @unique @map("operator_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  bookings            Booking[] @relation("TractorBookings")
  fuelLogs            FuelLog[] @relation("TractorFuelLogs")
  operator            User?     @relation("OperatorTractor", fields: [operatorId], references: [id])

  @@map("tractors")
}

model FuelLog {
  id         Int      @id @default(autoincrement())
  operatorId Int      @map("operator_id")
  tractorId  Int?     @map("tractor_id")
  liters     Float
  cost       Float
  station    String
  receiptUrl String?  @map("receipt_url")
  createdAt  DateTime @default(now()) @map("created_at")
  operator   User     @relation("OperatorFuelLogs", fields: [operatorId], references: [id])
  tractor    Tractor? @relation("TractorFuelLogs", fields: [tractorId], references: [id])

  @@index([operatorId], map: "fuel_logs_operator_id_fkey")
  @@index([tractorId], map: "fuel_logs_tractor_id_fkey")
  @@map("fuel_logs")
}

model FuelPriceLog {
  id        Int      @id @default(autoincrement())
  oldPrice  Float    @map("old_price")
  newPrice  Float    @map("new_price")
  adminId   Int      @map("admin_id")
  timestamp DateTime @default(now()) @map("timestamp")

  @@map("fuel_price_logs")
}

